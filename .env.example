# Flask Configuration
# Flask 配置

# WARNING: Copy this file to .env and fill in your values. NEVER commit .env to git.
# 警告：将此文件复制为 .env 并填入您的值。绝对不要将 .env 提交到 git。

# Secret key for Flask session management (REQUIRED in production)
# 用于 Flask 会话管理的秘密密钥（生产环境中必需）
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# 使用以下命令生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-with-secrets-module

# Enable debug mode (optional, default: False)
# 启用调试模式（可选，默认值：False）
# WARNING: NEVER set to True in production / 警告：绝对不要在生产环境中设置为 True
FLASK_DEBUG=False


# LLM Configuration (Large Language Model)
# LLM 配置（大型语言模型）

# OpenAI-compatible LLM API key (REQUIRED)
# OpenAI 兼容的 LLM API 密钥（必需）
LLM_API_KEY=sk-your-api-key-here

# LLM API base URL (optional, default: https://api.openai.com/v1)
# LLM API 基础 URL（可选，默认值：https://api.openai.com/v1）
# Examples / 示例：
# OpenAI: https://api.openai.com/v1
# Alibaba Qwen (Recommended) / 阿里巴巴通义千问（推荐）: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.openai.com/v1

# LLM model name (optional, default: gpt-4o-mini)
# LLM 模型名称（可选，默认值：gpt-4o-mini）
# Examples / 示例：
# OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Alibaba Qwen: qwen-plus, qwen-turbo
LLM_MODEL_NAME=gpt-4o-mini


# Zep Cloud Configuration (Agent Memory)
# Zep Cloud 配置（代理内存）

# Zep Cloud API key for agent memory management (REQUIRED)
# 用于代理内存管理的 Zep Cloud API 密钥（必需）
ZEP_API_KEY=your-zep-api-key-here


# Simulation Configuration
# 仿真配置

# Default maximum number of simulation rounds (optional, default: 10)
# 默认最大仿真轮数（可选，默认值：10）
OASIS_DEFAULT_MAX_ROUNDS=10


# Report Agent Configuration
# 报告代理配置

# Maximum number of tool calls per report generation (optional, default: 5)
# 每个报告生成的最大工具调用次数（可选，默认值：5）
REPORT_AGENT_MAX_TOOL_CALLS=5

# Maximum number of reflection iterations for report refinement (optional, default: 2)
# 报告优化的最大反思迭代次数（可选，默认值：2）
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2

# LLM temperature for report generation (optional, default: 0.5)
# 报告生成的 LLM 温度（可选，默认值：0.5）
# Range: 0.0-2.0 (lower = more deterministic, higher = more creative)
# 范围：0.0-2.0（低 = 更确定，高 = 更有创意）
REPORT_AGENT_TEMPERATURE=0.5